                      <rect x="1" y="1" width="80" height="80" stroke="white" stroke-width="1.25"></rect>
                      <rect x="1" y="1" width="80" height="80" fill="white" fill-opacity="0.3"></rect>
                      <rect x="1" y="1" width="80" height="80" stroke="white"></rect>
                      <path d="M1.40039 1.40002L80.4 80.4" stroke="white" stroke-width="2" stroke-linecap="round" stroke-dasharray="0.01 5"></path>
                      <rect id="green-square-4" x="1" y="1" width="80" height="80" fill="#94B21A" fill-opacity="1" stroke="white" vector-effect="non-scaling-stroke"></rect>
