<script is:inline>
document.addEventListener('DOMContentLoaded', function () {
            // Create enlarged image container
            var enlargedContainer = document.createElement('div');
            enlargedContainer.className = 'enlarged-image-container';
            enlargedContainer.innerHTML = '<img class="enlarged-image" src="" alt="Enlarged image">';
            document.body.appendChild(enlargedContainer);

            var enlargedImg = enlargedContainer.querySelector('.enlarged-image');

            // Add click event to all images in image-containers
            var images = document.querySelectorAll('.image-container img');
            images.forEach(function (img) {
                img.addEventListener('click', function (event) {
                    event.stopPropagation(); // Prevent the document click event from firing
                    enlargedContainer.style.display = "block";
                    enlargedImg.src = this.currentSrc || this.src;
                });
            });

            // Close the enlarged image when clicking anywhere on the document
            document.addEventListener('click', function () {
                if (enlargedContainer.style.display === "block") {
                    enlargedContainer.style.display = "none";
                }
            });

            // Close the enlarged image when pressing the Escape key
            document.addEventListener('keydown', function (event) {
                if (event.key === "Escape" && enlargedContainer.style.display === "block") {
                    enlargedContainer.style.display = "none";
                }
            });
        });
</script>
<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('compute-headroom-button').onmousemove = e => {
                const rect = e.target.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                e.target.style.setProperty('--x', `${x}px`);
                e.target.style.setProperty('--y', `${y}px`);
            };
        });
</script>
<script is:inline>
document.addEventListener('DOMContentLoaded', () => {
            const browserLinks = document.querySelectorAll('.browser-link');

            browserLinks.forEach(link => {
                link.addEventListener('click', () => {
                    const url = link.getAttribute('data-url');
                    navigator.clipboard.writeText(url).then(() => {
                        // Create and show tooltip
                        const tooltip = document.createElement('span');
                        tooltip.className = 'tooltiptext';
                        tooltip.textContent = 'Copied!';
                        link.classList.add('tooltip');
                        link.appendChild(tooltip);

                        // Remove tooltip after 2 seconds
                        setTimeout(() => {
                            link.removeChild(tooltip);
                            link.classList.remove('tooltip');
                        }, 2000);
                    });
                });
            });
        });
</script>
</BaseLayout>