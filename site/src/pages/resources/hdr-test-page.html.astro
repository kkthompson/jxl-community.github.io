---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'HDR Test Page – JPEG XL';
const description = 'See how your browser and display handle HDR content in JXL and other formats.';
---
<BaseLayout title={title} description={description} canonical="https://jpegxl.info/resources/hdr-test-page.html">
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://jpegxl.info/resources/hdr-test-page.html" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://jpegxl.info/images/OG_Image-JPEG_XL-neon-tunnel-glow.webp" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@JpegXl" />
    <meta property="twitter:url" content="https://jpegxl.info/resources/hdr-test-page.html" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://jpegxl.info/images/OG_Image-JPEG_XL-neon-tunnel-glow.webp" />
    <script is:inline>
let sd = 0;
        async function headroom() {
            let factor; // Declare factor here so it's accessible outside the try block
            try {
                if (sd === 0) sd = await window.getScreenDetails();
                factor = sd.currentScreen.highDynamicRangeHeadroom;

                // Check if the factor is a valid number
                if (factor && factor > 0) {
                    // Function to format number and remove trailing zeros
                    function formatNumber(num) {
                        return parseFloat(num.toFixed(3)).toString();
                    }

                    let s = "HDR headroom: " + formatNumber(Math.log2(factor)) +
                        "\u2002(up to " + formatNumber(factor) + " times SDR white)";
                    document.getElementById("headroom").textContent = s;
                } else {
                    document.getElementById("headroom").textContent = "HDR factor not available or invalid.";
                }

                // Set up listener for screen change
                sd.oncurrentscreenchange = () => { headroom(); };
            } catch (err) {
                console.error("Error getting screen details:", err);
                document.getElementById("headroom").textContent = "Unable to retrieve HDR headroom information.";
            }

            // Log factor and ScreenDetails object
            console.log("ScreenDetails object:", sd);
            console.log("HDR headroom factor:", factor);
        }
</script>
    <style is:inline>
      .text-center {
                  text-align: center;
              }
      
              .image-grid-container {
                  display: grid;
                  grid-template-columns: repeat(3, 1fr);
                  gap: 10px;
                  width: 100%;
                  max-width: 100%;
                  /* Changed from 1200px to 100% */
                  margin: 0 auto;
                  padding: 0 20px;
                  /* Added padding to prevent edge-to-edge content */
              }
      
              .image-card {
                  display: flex;
                  flex-direction: column;
                  align-items: center;
                  padding: 10px;
                  box-sizing: border-box;
              }
      
              .image-title {
                  min-height: 20px;
                  margin-bottom: 8px;
                  text-align: center;
                  font-size: 14px;
                  font-weight: 300;
                  line-height: 1.2;
                  color: #ffffff;
                  width: 100%;
                  display: flex;
                  align-items: flex-end;
                  justify-content: center;
              }
      
              .image-container {
                  width: 100%;
                  height: 250px;
                  display: flex;
                  justify-content: center;
                  align-items: center;
                  position: relative;
                  margin-top: 4px;
              }
      
              /* Fix for picture elements and images to maintain consistent sizing */
              .image-container picture {
                  width: 100%;
                  height: 100%;
                  display: flex;
                  justify-content: center;
                  align-items: center;
              }
      
              .image-container img {
                  max-width: 100%;
                  max-height: 100%;
                  width: auto;
                  height: auto;
                  object-fit: contain;
                  display: block;
              }
      
              /* For the webp fallbacks specifically */
              .image-container picture img {
                  max-width: 100%;
                  max-height: 100%;
                  width: auto;
                  height: auto;
                  object-fit: contain;
                  aspect-ratio: inherit;
              }
      
              /* Match the width of the parent container */
              .container-content-vflex .w-container {
                  width: 100%;
                  max-width: 100%;
              }
      
              /* Responsive adjustments */
              @media (max-width: 1440px) {
      
                  /* Explicitly center content below 1440px */
                  .section-content-wrapper,
                  .container-content-vflex,
                  .w-layout-blockcontainer.w-container {
                      justify-content: center;
                      align-items: center;
                  }
              }
      
              @media (max-width: 992px) {
                  .image-grid-container {
                      grid-template-columns: repeat(2, 1fr);
                  }
      
                  .image-title {
                      min-height: 50px;
                  }
              }
      
              @media (max-width: 576px) {
                  .image-grid-container {
                      grid-template-columns: 1fr;
                      padding: 0 10px;
                  }
      
                  .image-card {
                      max-width: 100%;
                      margin: 0 auto;
                  }
      
                  .image-title {
                      min-height: auto;
                  }
      
                  .image-container {
                      height: 220px;
                  }
              }
      
              /* Keep other styles unchanged */
              #compute-headroom-button {
                  --x: 50%;
                  --y: 50%;
                  position: relative;
                  margin-top: 20px;
                  padding: .5em 1.9em;
                  color: var(--text--color--text-white);
                  font-family: Barlow, sans-serif;
                  font-size: 18px;
                  text-transform: uppercase;
                  font-weight: 400;
                  cursor: pointer;
                  outline: none;
                  border-radius: 100px;
                  border: 2px solid transparent;
                  background: linear-gradient(#111111, #111111) padding-box, radial-gradient(farthest-corner at var(--x) var(--y), oklch(83.77% 0.1936 191.95), oklch(57.16% 0.2513 261.98)) border-box;
                  transition: all 0.3s ease;
              }
      
              #compute-headroom-button:hover {
                  background: linear-gradient(#292929, #222222) padding-box, radial-gradient(farthest-corner at var(--x) var(--y), oklch(83.77% 0.1936 191.95), oklch(57.16% 0.2513 261.98)) border-box;
              }
      
              #compute-headroom-button:active {
                  background: linear-gradient(to right, oklch(83.77% 0.1936 191.95), oklch(57.16% 0.2513 261.98)) padding-box, radial-gradient(farthest-corner at var(--x) var(--y), oklch(83.77% 0.1936 191.95), oklch(57.16% 0.2513 261.98)) border-box;
                  color: oklch(13.45% 0 0);
              }
      
              .browser-link {
                  cursor: pointer;
                  text-decoration: none;
                  color: oklch(83.77% 0.1936 191.95);
              }
      
              .tooltip {
                  position: relative;
                  display: inline-block;
              }
      
              .tooltip .tooltiptext {
                  visibility: hidden;
                  width: 140px;
                  background-color: #555;
                  color: var(--text--color--text-white);
                  text-align: center;
                  border-radius: 6px;
                  padding: 5px;
                  position: absolute;
                  z-index: 1;
                  bottom: 150%;
                  left: 50%;
                  margin-left: -75px;
                  opacity: 0;
                  transition: opacity 0.3s;
              }
      
              .tooltip .tooltiptext::after {
                  content: "";
                  position: absolute;
                  top: 100%;
                  left: 50%;
                  margin-left: -5px;
                  border-width: 5px;
                  border-style: solid;
                  border-color: #555 transparent transparent transparent;
              }
      
              .tooltip:hover .tooltiptext {
                  visibility: visible;
                  opacity: 1;
              }
      
              .text-style-small {
                  letter-spacing: .01em;
                  color: var(--text--color--text-white);
              }
      
              .enlarged-image-container {
                  display: none;
                  position: fixed;
                  z-index: 1000;
                  left: 50%;
                  top: 50%;
                  transform: translate(-50%, -50%);
                  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
                  cursor: pointer;
              }
      
              .enlarged-image {
                  display: block;
                  max-width: 90vw;
                  max-height: 90vh;
                  object-fit: contain;
              }
    </style>
