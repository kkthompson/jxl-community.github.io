---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Software Support – JPEG XL';
const description = 'Find applications, libraries, and tools that support JPEG XL encoding and decoding.';
---
<BaseLayout title={title} description={description} canonical="https://jpegxl.info/resources/software-support.html">
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://jpegxl.info/resources/software-support.html" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://jpegxl.info/images/OG_Image-JPEG_XL-neon-tunnel-glow.webp" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@JpegXl" />
    <meta property="twitter:url" content="https://jpegxl.info/resources/software-support.html" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://jpegxl.info/images/OG_Image-JPEG_XL-neon-tunnel-glow.webp" />
    <script type="module" src="https://caniuse-embed.vercel.app/embed.js"></script>
    <style is:inline>
      #ciu-embed-wrap { width: 100%; min-width: 0; }
          #ciu-embed-wrap .ciu-embed, #ciu-embed-wrap iframe { width: 100% !important; max-width: 100%; min-width: 0; }
    </style>
  </Fragment>
<section id="main-content" class="section-hero hero-fullspan-graphic gradient-bottom">
      <main class="container-content-vflex padding-sides">
        <div class="container-content-vflex centered">
          <div class="wrapper-text color-gradient">
            <h1 class="display-xl-bold fill-gradient">Software Support</h1>
          </div>
          <div class="wrapper-text width-small">
            <h2 class="text-l-medium large">Standardized in 2022, JPEG&nbsp;XL is quickly gaining momentum. Major
              operating systems, web browsers, and image editing software are increasingly adopting support for this
              efficient compression technology.</h2>
          </div>
        </div>
      </main>
      <div class="container-wave-animated">
        <div class="wrapper-content-wave centered align-middle height-cropped-width-full"><img
            src="/images/Ripple-Line2x-50.0s-2560px-371px.svg" loading="lazy" alt="" class="image-wave-2560"><img
            src="/images/Ripple-Line2x-50.0s-1440px-300px.svg" loading="lazy" alt="" class="image-wave-1440"></div>
      </div>
    </section>
    <div class="section-content-wrapper height-100 centered padding-top_bottom">
      <main class="container-content-vflex width-page-max centered">
        <div class="container-content-vflex width-page-max">
          <div class="wrapper-content centered">
            <div class="group-container">
              <div class="text-xl-regular color-black">Libraries & APIs</div>
