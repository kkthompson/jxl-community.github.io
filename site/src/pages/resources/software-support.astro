                <div class="wrapper-logo-text">
                  <a href="https://github.com/libjxl/libjxl" target="_blank" rel="noopener noreferrer"
                    class="wrapper-logo-software-link w-inline-block"><img src="/images/libjxl-logo.svg" loading="lazy"
                      width="140" alt="libjxl logo" class="image-logo-software"></a>
                  <div class="text-small-regular centered color-black">
                    <a href="https://github.com/libjxl/libjxl" target="_blank" rel="noopener noreferrer" class="link-text-body-underline">libjxl:
                    </a>JPEG XL reference implementation (C++)<br>
                    <a href="https://artifacts.lucaversari.it/libjxl/libjxl/latest/" target="_blank" rel="noopener noreferrer"
                      class="link-text-body-underline">Nightly Dev Builds</a><br>
                    <div class="spacer-2rem"></div>
                    <a href="https://github.com/libjxl/jxl-rs" target="_blank" rel="noopener noreferrer"
                      class="link-text-body-underline">jxl-rs</a> Rust decoder<br>‍
                    <a href="https://github.com/Traneptora/jxlatte" target="_blank" rel="noopener noreferrer"
                      class="link-text-body-underline">jxlatte:</a> Java decoder<br>‍
                    <a href="https://github.com/tirr-c/jxl-oxide" target="_blank" rel="noopener noreferrer"
                      class="link-text-body-underline">jxl-oxide:‍</a> Rust decoder<br>
                  </div>
                </div>
              </div>
            </div>
            <div class="spacer-2rem"></div>
            <div class="group-container">
              <div class="text-xl-regular color-black">Operating Systems</div>
              <div class="container-logos">
                <div class="wrapper-logo-text">
                  <a href="https://www.apple.com" target="_blank" rel="noopener noreferrer" class="wrapper-logo-software-link w-inline-block"><img
