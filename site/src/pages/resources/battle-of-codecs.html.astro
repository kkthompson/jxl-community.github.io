---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Battle of the Codecs – JPEG XL';
const description = 'See how JPEG XL stacks up against other file formats.';
---
<BaseLayout title={title} description={description} canonical="https://jpegxl.info/resources/battle-of-codecs.html">
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://jpegxl.info/resources/battle-of-codecs.html" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://jpegxl.info/images/OG_Image-JPEG_XL-neon-tunnel-glow.webp" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@JpegXl" />
    <meta property="twitter:url" content="https://jpegxl.info/resources/battle-of-codecs.html" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://jpegxl.info/images/OG_Image-JPEG_XL-neon-tunnel-glow.webp" />
    <style is:inline>
      :root {
                  --first-col-width: 213px;
                  --jxl-col-width: 120px;
                  --other-col-width: 110px;
              }
      
              /* Prevent the wide table from pushing the flex ancestors past the viewport,
                 which would cause the whole page to scroll horizontally instead of just the table.
                 min-width: 0 lets flex items shrink below their content size. */
              #main-content,
              #main-content .section-content-wrapper,
              #main-content .container-content-vflex {
                  min-width: 0;
              }
      
              /* Below the 1200px page-max cap, also enforce max-width: 100% so the
                 container can't stretch past the viewport when its inner table is wide.
                 Above 1200px the page-max class's own max-width: 1200px keeps things
                 centered inside the normal page bounds — don't override it here. */
              @media (max-width: 1199px) {
                  #main-content,
                  #main-content .section-content-wrapper,
                  #main-content .container-content-vflex {
                      max-width: 100%;
                  }
              }
      
              .table-container {
                  width: 100%;
                  max-width: 100%;
                  overflow-x: auto;
                  position: relative;
                  font-size: 14px;
                  font-weight: 300;
                  display: block;
                  line-height: normal;
                  color: #ffffff;
                  overscroll-behavior-x: contain;
                  touch-action: pan-x pan-y;
              }
      
              table {
                  border-collapse: separate;
                  border-spacing: 0;
                  width: max-content;
              }
      
              th,
              td {
                  padding: 6.5px 8px;
                  vertical-align: middle;
              }
      
              th:not(:first-child),
              td:not(:first-child) {
                  word-wrap: break-word;
                  text-align: center;
              }
      
              th:not(:first-child):not(.jpeg-xl),
              td:not(:first-child):not(.jpeg-xl) {
                  width: var(--other-col-width);
                  min-width: var(--other-col-width);
              }
      
              th {
                  background-color: #1d1d1d;
                  position: sticky;
                  top: 0;
                  z-index: 10;
                  text-align: center;
                  font-weight: 500;
              }
      
              th:not(.fixed-column)::before {
                  content: '';
                  position: absolute;
                  top: 0px;
                  /* Adjusted to create space at the top */
                  left: 4px;
                  /* Creates gap on the left */
                  right: 4px;
                  /* Creates gap on the right */
                  bottom: 0;
                  background-color: #5a5a5a;
                  border-top-left-radius: 10px;
                  border-top-right-radius: 10px;
                  z-index: -1;
              }
      
              th:not(:first-child) {
                  font-size: 15px;
                  font-weight: 400;
              }
      
              th:not(:first-child) .date {
                  font-size: 75%;
                  display: block;
              }
      
              .fixed-column {
                  position: sticky;
                  background-color: #1d1d1d;
                  left: 0;
                  z-index: 30;
                  width: var(--first-col-width);
                  min-width: var(--first-col-width);
                  max-width: var(--first-col-width);
                  word-wrap: break-word;
                  overflow-wrap: break-word;
              }
      
              td.fixed-column {
                  background-color: #1d1d1d;
                  z-index: 25;
              }
      
              .jpeg-xl {
                  position: sticky;
                  left: var(--first-col-width);
                  z-index: 20;
                  width: var(--jxl-col-width);
                  min-width: var(--jxl-col-width);
                  max-width: var(--jxl-col-width);
                  /* Right-edge shadow to visually communicate that other columns slide under this one. */
                  box-shadow: 4px 0 6px -2px rgba(0, 0, 0, 0.5);
              }
      
              td.jpeg-xl {
                  background-color: #2c2c2c;
              }
      
              th.fixed-column {
                  z-index: 35;
              }
      
              th.jpeg-xl {
                  z-index: 30;
              }
      
              .section-header td {
                  font-weight: 500;
                  padding: 10px 8px;
                  border-top: .5px solid white;
                  border-bottom: .5px solid white;
              }
      
              .section-header td:first-child {
                  text-align: left !important;
                  padding-left: 8px !important;
              }
      
              .sub-row td:first-child {
                  padding-left: 28px;
              }
      
              .star-rating {
                  display: inline-flex;
                  flex-direction: row;
                  align-items: center;
                  line-height: 1;
                  justify-content: center;
              }
      
              .star-rating::before {
                  content: '★★★★';
                  letter-spacing: 7px;
                  background: linear-gradient(90deg, gold var(--percent), #888 var(--percent));
                  -webkit-background-clip: text;
                  -webkit-text-fill-color: transparent;
                  font-size: 1.3em;
              }
      
              .progress-bar {
                  width: 100%;
                  height: 10px;
                  background-color: #444;
                  border-radius: 5px;
                  overflow: hidden;
                  margin: 0 auto;
              }
      
              .progress-bar-fill {
                  height: 100%;
                  background-color: #94B21A;
                  width: var(--percent);
                  border-radius: 5px;
              }
      
              .green-check,
              .red-cross {
                  display: inline-block;
                  width: 24px;
                  height: 24px;
                  vertical-align: middle;
              }
      
              .green-check svg,
              .red-cross svg {
                  width: 24px;
                  height: 24px;
              }
      
              .na {
                  color: #888;
              }
      
              .additional-info {
                  display: inline-block;
                  font-size: 0.8em;
                  font-weight: 400;
                  margin-left: 4px;
                  vertical-align: middle;
              }
      
              @media (max-width: 991px) {
                  :root {
                      --first-col-width: 180px;
                      --jxl-col-width: 110px;
                      --other-col-width: 100px;
                  }
      
                  /* Cap container height so vertical scroll happens INSIDE the table.
                     This gives the sticky <th> headers a real scroll context to anchor
                     to — without it, sticky top: 0 has nothing to react to on page scroll. */
                  .table-container {
                      max-height: 75vh;
                      overflow-y: auto;
                  }
              }
      
              @media (max-width: 767px) {
                  :root {
                      --first-col-width: 140px;
                      --jxl-col-width: 105px;
                      --other-col-width: 95px;
                  }
                  .table-container {
                      font-size: 13px;
                  }
              }
      
              @media (max-width: 479px) {
                  :root {
                      --first-col-width: 118px;
                      --jxl-col-width: 95px;
                      --other-col-width: 88px;
                  }
                  .table-container {
                      font-size: 12px;
                  }
      
                  th,
                  td {
                      padding: 6px 4px;
                  }
      
                  .star-rating::before {
                      letter-spacing: 4px;
                  }
              }
    </style>
  </Fragment>
